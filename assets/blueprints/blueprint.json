{
	"$schema": "https://playground.wordpress.net/blueprint-schema.json",
	"features": {
		"networking": true
	},
	"landingPage": "/wp-admin/admin.php?page=kudos-campaigns",
	"preferredVersions": {
		"php": "8.4",
		"wp": "latest"
	},
	"phpExtensionBundles": ["kitchen-sink"],
	"steps": [
		{
			"step": "login",
			"username": "admin",
			"password": "password"
		},
		{
			"step": "setSiteOptions",
			"options": {
				"blogname": "Kudos Donations Demo",
				"_kudos_payment_vendor": "demo",
				"_kudos_payment_vendor_status": {
					"ready": true,
					"text": "Mollie ready (Demo account)"
				}
			}
		},
		{
			"step": "defineWpConfigConsts",
			"consts": {
				"KUDOS_DEMO_MODE": true
			}
		}

	]
}
